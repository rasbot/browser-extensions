{
  "manifest_version": 3,
  "name": "SVEN",
  "version": "1.0",
  "description": "Translate between English and Swedish by selecting text",
  "permissions": ["storage", "clipboardRead"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_ensv.png",
      "48": "icons/icon48_ensv.png",
      "128": "icons/icon128_ensv.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16_ensv.png",
    "48": "icons/icon48_ensv.png",
    "128": "icons/icon128_ensv.png"
  }
}
